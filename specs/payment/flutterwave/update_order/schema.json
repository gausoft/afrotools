{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "update_order",
  "capability_type": "synchronous",
  "status": "ready",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "PUT",
    "url": "https://f4bexperience.flutterwave.com/orders/{id}"
  },
  "example_prompt": "Void an authorized Flutterwave v4 order, or capture an authorized order before settlement.",
  "input_schema": {
    "type": "object",
    "required": ["id"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique Flutterwave identifier of the order to update (e.g. ord_EFAHCzELJb)."
      },
      "action": {
        "type": "string",
        "enum": ["void", "capture"],
        "description": "Operation to perform on the order: void cancels an authorized hold, capture completes it."
      },
      "meta": {
        "type": "object",
        "description": "Arbitrary merchant metadata to merge into the order. Values are strings per docs.",
        "additionalProperties": { "type": "string" }
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      },
      "scenario_key": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000,
        "description": "Optional X-Scenario-Key header used in sandbox to simulate specific scenarios."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "properties": {
      "status": { "type": "string", "enum": ["success", "failed"] },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "description": "Full updated order resource, identical in shape to the create_order / get_order response.",
        "properties": {
          "id": { "type": "string", "description": "Flutterwave order id, e.g. ord_WRq7L4TM8p." },
          "amount": { "type": "number", "minimum": 0.01 },
          "fees": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "amount": { "type": "number" }
              }
            }
          },
          "billing_details": {
            "type": "object",
            "properties": {
              "email": { "type": "string" },
              "name": {
                "type": "object",
                "properties": {
                  "first": { "type": "string" },
                  "middle": { "type": "string" },
                  "last": { "type": "string" }
                }
              },
              "phone": {
                "type": "object",
                "properties": {
                  "country_code": { "type": "string" },
                  "number": { "type": "string" }
                }
              }
            }
          },
          "currency": { "type": "string" },
          "customer_id": { "type": "string" },
          "description": { "type": "string" },
          "meta": { "type": "object", "additionalProperties": true },
          "next_action": { "type": "object", "additionalProperties": true },
          "payment_method_details": { "type": "object", "additionalProperties": true },
          "redirect_url": { "type": "string", "format": "uri" },
          "reference": { "type": "string", "minLength": 6, "maxLength": 42 },
          "status": {
            "type": "string",
            "enum": ["completed", "pending", "authorized", "partially-completed", "voided", "failed"]
          },
          "processor_response": {
            "type": "object",
            "properties": {
              "type": { "type": "string" },
              "code": { "type": "string" }
            },
            "additionalProperties": true
          },
          "created_datetime": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            },
            "description": "Present on 400 validation errors."
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "The PUT body accepts only two documented fields: action ('void' | 'capture') and meta. There is no documented authorization payload on update — supply 3DS / SCA at create_order time instead.",
    "Terminal statuses (completed, voided, failed) typically reject further updates with 10409 RESOURCE_CONFLICT.",
    "action='capture' is only valid for orders currently in the 'authorized' status (manual-capture flows); action='void' cancels an authorization before capture."
  ]
}
