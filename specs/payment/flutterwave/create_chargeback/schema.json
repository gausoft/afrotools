{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "create_chargeback",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "POST",
    "url": "https://f4bexperience.flutterwave.com/chargebacks"
  },
  "example_prompt": "Open a chargeback dispute on a Flutterwave charge for fraud, attaching investigation notes.",
  "input_schema": {
    "type": "object",
    "required": ["charge_id", "amount", "expiry", "type"],
    "properties": {
      "charge_id": {
        "type": "string",
        "description": "Id of the associated charge being disputed."
      },
      "amount": {
        "type": "number",
        "minimum": 0.01,
        "description": "Chargeback amount in decimal format. Minimum 0.01."
      },
      "expiry": {
        "type": "integer",
        "description": "Duration in hours used to compute due_datetime."
      },
      "type": {
        "type": "string",
        "enum": ["local", "international"],
        "description": "Chargeback type."
      },
      "stage": {
        "type": "string",
        "enum": ["new", "second", "pre-arbitration", "arbitration"],
        "description": "Optional chargeback stage."
      },
      "status": {
        "type": "string",
        "enum": ["pending", "initiated"],
        "description": "Optional initial status."
      },
      "uploaded_proof": {
        "type": "string",
        "description": "Optional URL of an uploaded proof document."
      },
      "comment": {
        "type": "string",
        "description": "Optional additional notes."
      },
      "provider": {
        "type": "string",
        "description": "Optional card scheme / provider name (e.g. Visa)."
      },
      "arn": {
        "type": "string",
        "description": "Optional Acquirer Reference Number."
      },
      "initiator": {
        "type": "string",
        "description": "Optional chargeback originator (e.g. Cardholder)."
      },
      "idempotency_key": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "X-Idempotency-Key header value (12-255 chars) for duplicate prevention."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value (12-255 chars) for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": { "type": "string", "enum": ["success"] },
      "message": { "type": "string" },
      "meta": { "type": "object", "additionalProperties": true },
      "data": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "charge_id": { "type": "string" },
          "amount": { "type": "number" },
          "stage": {
            "type": "string",
            "enum": ["new", "second", "pre-arbitration", "arbitration", "invalid"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "accepted", "declined", "initiated", "won", "lost", "reversed", "new"]
          },
          "type": { "type": "string", "enum": ["local", "international"] },
          "due_datetime": { "type": "string", "format": "date-time" },
          "created_datetime": { "type": "string", "format": "date-time" },
          "updated_datetime": { "type": "string", "format": "date-time" },
          "settlement_id": { "type": "string" },
          "uploaded_proof": { "type": "string" },
          "comment": { "type": "string" },
          "provider": { "type": "string" },
          "arn": { "type": "string" },
          "initiator": { "type": "string" },
          "meta": { "type": "object", "additionalProperties": true }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": { "type": "array", "items": { "type": "object", "properties": { "field_name": { "type": "string" }, "message": { "type": "string" } } } }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "Required body fields are charge_id, amount, expiry (hours), and type (local|international). expiry sets the deadline (due_datetime) by which the chargeback must be resolved.",
    "Always send X-Idempotency-Key (12-255 chars) on POST so retries do not create duplicate chargeback records.",
    "Initial status can only be set to pending or initiated at creation; later transitions (accepted/declined/won/lost/...) are made through update_chargeback.",
    "Returns 201 with the created chargeback in data. The chargeback then progresses asynchronously — poll get_chargeback or rely on webhook events for the final outcome."
  ]
}
