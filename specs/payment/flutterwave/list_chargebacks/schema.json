{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "list_chargebacks",
  "capability_type": "synchronous",
  "status": "ready",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/chargebacks"
  },
  "example_prompt": "List Flutterwave chargebacks raised in the last 30 days.",
  "input_schema": {
    "type": "object",
    "properties": {
      "page": {
        "type": "integer",
        "minimum": 1,
        "default": 1,
        "description": "The page of the data to retrieve. The most recent data entry is on page 1."
      },
      "size": {
        "type": "integer",
        "minimum": 10,
        "maximum": 50,
        "default": 10,
        "description": "Length of data returned. Defaults to 10. Min 10, max 50."
      },
      "from": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 start date-time of the period to retrieve chargebacks for."
      },
      "to": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 end date-time of the period to retrieve chargebacks for."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value (12-255 chars) for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": { "type": "string", "enum": ["success"] },
      "message": { "type": "string" },
      "meta": {
        "type": "object",
        "properties": {
          "page_info": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "current_page": { "type": "integer" },
              "total_pages": { "type": "integer" }
            }
          }
        }
      },
      "data": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "charge_id": { "type": "string" },
            "amount": { "type": "number" },
            "meta": { "type": "object", "additionalProperties": true },
            "stage": {
              "type": "string",
              "enum": ["new", "second", "pre-arbitration", "arbitration", "invalid"]
            },
            "status": {
              "type": "string",
              "enum": ["pending", "accepted", "declined", "initiated", "won", "lost", "reversed", "new"]
            },
            "type": { "type": "string", "enum": ["local", "international"] },
            "due_datetime": { "type": "string", "format": "date-time" },
            "created_datetime": { "type": "string", "format": "date-time" },
            "updated_datetime": { "type": "string", "format": "date-time" },
            "settlement_id": { "type": "string" },
            "uploaded_proof": { "type": "string" },
            "comment": { "type": "string" },
            "provider": { "type": "string" },
            "arn": { "type": "string" },
            "initiator": { "type": "string" }
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": { "type": "array", "items": { "type": "object", "properties": { "field_name": { "type": "string" }, "message": { "type": "string" } } } }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "Page size is bounded by the API: 10 minimum, 50 maximum. Defaults to 10.",
    "from and to must be ISO 8601 date-times. The most recent chargebacks are on page 1.",
    "Each chargeback carries a stage (new/second/pre-arbitration/arbitration/invalid) and a status (pending/accepted/declined/initiated/won/lost/reversed/new). Both must be inspected to know what action is required.",
    "Chargebacks are typically initiated by the cardholder via the issuing bank; this endpoint surfaces them so the merchant can respond before due_datetime."
  ]
}
