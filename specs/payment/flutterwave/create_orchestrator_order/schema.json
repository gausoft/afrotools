{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "create_orchestrator_order",
  "capability_type": "synchronous",
  "status": "ready",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "POST",
    "url": "https://f4bexperience.flutterwave.com/orchestration/direct-orders"
  },
  "example_prompt": "Create a Flutterwave preauth order for 10000 NGN with an inline customer, to be captured later via a charge.",
  "input_schema": {
    "type": "object",
    "required": ["amount", "currency", "reference", "customer", "payment_method"],
    "properties": {
      "amount": {
        "type": "number",
        "minimum": 0.01,
        "description": "Amount to authorize. Must be at least 0.01."
      },
      "currency": {
        "type": "string",
        "description": "ISO 4217 currency code (e.g. \"NGN\")."
      },
      "reference": {
        "type": "string",
        "minLength": 6,
        "maxLength": 42,
        "pattern": "^[a-zA-Z0-9\\-]+$",
        "description": "Merchant-supplied unique reference (6-42 alphanumeric chars with hyphens). Reusing returns 409."
      },
      "customer": {
        "type": "object",
        "required": ["email"],
        "description": "Inline customer object — Flutterwave creates or matches the customer based on these fields.",
        "properties": {
          "email": { "type": "string", "format": "email" },
          "name": {
            "type": "object",
            "properties": {
              "first": { "type": "string" },
              "middle": { "type": "string" },
              "last": { "type": "string" }
            }
          },
          "phone": {
            "type": "object",
            "required": ["number", "country_code"],
            "properties": {
              "country_code": { "type": "string" },
              "number": { "type": "string" }
            }
          },
          "address": {
            "type": "object",
            "required": ["line1", "city", "state", "country", "postal_code"],
            "properties": {
              "line1": { "type": "string" },
              "line2": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "country": {
                "type": "string",
                "pattern": "^[A-Z]{2}$",
                "description": "ISO 3166-1 alpha-2 country code (e.g. \"NG\")."
              },
              "postal_code": { "type": "string" }
            }
          }
        }
      },
      "payment_method": {
        "type": "object",
        "required": ["type"],
        "description": "Discriminated union on type. Supply exactly one of card | bank_account | mobile_money | opay | applepay | googlepay | ussd and the matching sub-object.",
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "card"],
            "properties": {
              "type": { "type": "string", "enum": ["card"] },
              "customer_id": { "type": "string" },
              "card": {
                "type": "object",
                "required": ["nonce", "encrypted_card_number", "encrypted_expiry_month", "encrypted_expiry_year"],
                "properties": {
                  "nonce": {
                    "type": "string",
                    "minLength": 12,
                    "maxLength": 12,
                    "description": "12-character single-use nonce paired with the encrypted fields."
                  },
                  "encrypted_card_number": { "type": "string" },
                  "encrypted_expiry_month": { "type": "string" },
                  "encrypted_expiry_year": { "type": "string" },
                  "encrypted_cvv": { "type": "string" },
                  "card_holder_name": { "type": "string" },
                  "billing_address": {
                    "type": "object",
                    "required": ["line1", "city", "state", "country", "postal_code"],
                    "properties": {
                      "line1": { "type": "string" },
                      "line2": { "type": "string" },
                      "city": { "type": "string" },
                      "state": { "type": "string" },
                      "country": { "type": "string", "pattern": "^[A-Z]{2}$" },
                      "postal_code": { "type": "string" }
                    }
                  },
                  "cof": {
                    "type": "object",
                    "required": ["enabled"],
                    "properties": {
                      "enabled": { "type": "boolean" },
                      "agreement_id": { "type": "string" },
                      "trace_id": { "type": "string" }
                    }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["bank_account"] }
            }
          },
          {
            "type": "object",
            "required": ["type", "mobile_money"],
            "properties": {
              "type": { "type": "string", "enum": ["mobile_money"] },
              "mobile_money": {
                "type": "object",
                "required": ["network", "phone_number", "country_code"],
                "properties": {
                  "network": { "type": "string", "description": "Network operator (e.g. MTN, AIRTEL)." },
                  "country_code": { "type": "string", "description": "Country dialling code as digits only." },
                  "phone_number": { "type": "string", "description": "Subscriber number digits only (no country code)." },
                  "use_qr": { "type": "boolean" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["opay"] }
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["applepay"] },
              "applepay": {
                "type": "object",
                "properties": {
                  "card_holder_name": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["googlepay"] },
              "googlepay": {
                "type": "object",
                "properties": {
                  "card_holder_name": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "ussd"],
            "properties": {
              "type": { "type": "string", "enum": ["ussd"] },
              "ussd": {
                "type": "object",
                "required": ["account_bank"],
                "properties": {
                  "account_bank": {
                    "type": "string",
                    "pattern": "^\\d{3,}$",
                    "description": "Nigerian bank code, digits only (e.g. \"050\")."
                  }
                }
              }
            }
          }
        ]
      },
      "authorization": {
        "type": "object",
        "required": ["type"],
        "description": "Authorization details (optional). Discriminated union on type — supply exactly one of otp | pin | external_3ds | avs and the matching sub-object.",
        "oneOf": [
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["otp"] },
              "otp": {
                "type": "object",
                "required": ["code"],
                "properties": {
                  "code": { "type": "string", "pattern": "^\\d{4,8}$" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["pin"] },
              "pin": {
                "type": "object",
                "required": ["encrypted_pin", "nonce"],
                "properties": {
                  "nonce": { "type": "string", "minLength": 12, "maxLength": 12 },
                  "encrypted_pin": { "type": "string" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "external_3ds"],
            "properties": {
              "type": { "type": "string", "enum": ["external_3ds"] },
              "external_3ds": {
                "type": "object",
                "required": ["eci", "authentication_token", "transaction_id", "version", "transaction_status", "status_reason_code", "amount", "time"],
                "properties": {
                  "eci": { "type": "string" },
                  "authentication_token": { "type": "string" },
                  "transaction_id": { "type": "string" },
                  "version": { "type": "string" },
                  "transaction_status": { "type": "string", "enum": ["Y", "N", "U", "A", "R"] },
                  "status_reason_code": { "type": "string" },
                  "amount": { "type": "number" },
                  "time": { "type": "string", "format": "date-time" }
                }
              }
            }
          },
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": { "type": "string", "enum": ["avs"] },
              "avs": {
                "type": "object",
                "required": ["address"],
                "properties": {
                  "address": {
                    "type": "object",
                    "required": ["line1", "city", "state", "country", "postal_code"],
                    "properties": {
                      "line1": { "type": "string" },
                      "line2": { "type": "string" },
                      "city": { "type": "string" },
                      "state": { "type": "string" },
                      "country": { "type": "string", "pattern": "^[A-Z]{2}$" },
                      "postal_code": { "type": "string" }
                    }
                  }
                }
              }
            }
          }
        ]
      },
      "redirect_url": {
        "type": "string",
        "format": "uri",
        "description": "URL to redirect the customer to after authorization flows that require it (e.g. 3DS)."
      },
      "merchant_vat_amount": {
        "type": "number",
        "description": "Optional VAT amount declared by the merchant."
      },
      "meta": {
        "type": "object",
        "description": "Free-form metadata stored on the order.",
        "additionalProperties": { "type": "string" }
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "X-Trace-Id header value for request correlation. REQUIRED on this endpoint."
      },
      "idempotency_key": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Idempotency-Key header value."
      },
      "scenario_key": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000,
        "description": "Optional X-Scenario-Key header value (test environment scenario selector)."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": { "type": "string", "enum": ["success", "failed"] },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Order id (e.g. ord_WRq7L4TM8p). Pass this as order_id when calling create_charge to capture funds." },
          "amount": { "type": "number" },
          "currency": { "type": "string" },
          "reference": { "type": "string" },
          "status": {
            "type": "string",
            "description": "Order lifecycle status (e.g. pending, authorized, captured, voided, failed)."
          },
          "customer_id": { "type": "string" },
          "payment_method_details": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["card", "bank_account", "mobile_money", "opay", "applepay", "googlepay", "ussd", "bank_transfer"]
              },
              "card": {
                "type": "object",
                "additionalProperties": true,
                "properties": {
                  "network": { "type": "string" },
                  "first6": { "type": "string" },
                  "last4": { "type": "string" },
                  "expiry_month": { "type": "integer" },
                  "expiry_year": { "type": "integer" }
                }
              }
            },
            "additionalProperties": true
          },
          "next_action": {
            "type": ["object", "null"],
            "description": "Discriminated by type. Possible types: redirect_url | requires_otp | requires_pin | requires_additional_fields | requires_requery | requires_capture | payment_instruction | requires_bank_transfer | qr_code.",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "redirect_url",
                  "requires_additional_fields",
                  "requires_pin",
                  "requires_otp",
                  "requires_requery",
                  "requires_capture",
                  "payment_instruction",
                  "requires_bank_transfer",
                  "qr_code"
                ]
              }
            },
            "additionalProperties": true
          },
          "created_datetime": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "An order is the preauth side of the preauth-and-capture flow: it authorizes the amount but does not capture funds. To capture, call create_charge with order_id set to the id returned here (e.g. ord_WRq7L4TM8p).",
    "Body shape is identical to create_orchestrator_charge — same inline customer object and same discriminated payment_method object — but the resource created is an order, not a charge. Do not confuse the two endpoints.",
    "payment_method is an OBJECT, not a string. Set payment_method.type to one of card | bank_account | mobile_money | opay | applepay | googlepay | ussd and provide the matching sub-object (e.g. { type: \"card\", card: { nonce, encrypted_card_number, ... } }).",
    "customer is an OBJECT (not customer_id). Email is required; name, phone, and address are optional structured sub-objects. Flutterwave creates or matches the customer behind the scenes.",
    "X-Trace-Id is REQUIRED on this endpoint (12-255 chars). Omitting it returns a 400 validation error — generate a fresh UUID per request.",
    "reference must be unique per merchant, match ^[a-zA-Z0-9-]+$ and be 6-42 chars. Reusing returns 409 Conflict.",
    "Successful creation returns HTTP 201 (not 200) with status=\"success\". The response uses created_datetime (not created_at) and customer_id (not nested customer).",
    "Card field encryption is mandatory — never POST raw PAN/CVV. Generate nonce + encrypted_* values via Flutterwave's field-level encryption SDK.",
    "Choose payment_method.type based on currency/country: card / applepay / googlepay are pan-African; mobile_money targets XAF/XOF/KES/UGX/RWF/TZS/GHS; opay and ussd target NGN; bank_account is region-dependent. A mismatch returns 400."
  ]
}
