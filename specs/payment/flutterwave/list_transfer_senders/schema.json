{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "list_transfer_senders",
  "capability_type": "synchronous",
  "status": "ready",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/transfers/senders"
  },
  "example_prompt": "List the next page of Flutterwave transfer senders using a cursor returned by a previous call, 20 per page.",
  "input_schema": {
    "type": "object",
    "properties": {
      "size": {
        "type": "integer",
        "minimum": 10,
        "maximum": 50,
        "default": 10,
        "description": "Length of data returned per page (10-50, default 10)."
      },
      "next": {
        "type": "string",
        "description": "Cursor for the next page of results — pass back the value from data.cursor.next of a previous response."
      },
      "previous": {
        "type": "string",
        "description": "Cursor for the previous page of results — pass back the value from data.cursor.previous of a previous response."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": { "type": "string", "enum": ["success"], "description": "\"success\" on 200." },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "required": ["senders", "cursor"],
        "properties": {
          "cursor": {
            "type": "object",
            "description": "Cursor-based pagination metadata.",
            "properties": {
              "next": { "type": ["string", "null"], "description": "Cursor for the next page, or null if last page." },
              "previous": { "type": ["string", "null"], "description": "Cursor for the previous page, or null if first page." },
              "limit": { "type": "integer", "description": "Page size used by the API." },
              "total": { "type": "integer", "description": "Total number of senders." },
              "has_more_items": { "type": "boolean", "description": "True if more senders are available beyond this page." }
            }
          },
          "senders": {
            "type": "array",
            "description": "Array of transfer sender objects.",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string", "description": "Sender id (use with get/delete_transfer_sender)." },
                "name": {
                  "type": "object",
                  "properties": {
                    "first": { "type": "string" },
                    "middle": { "type": "string" },
                    "last": { "type": "string" }
                  }
                },
                "national_identification": {
                  "type": "object",
                  "properties": {
                    "type": { "type": "string", "enum": ["PASSPORT", "DRIVERS_LICENSE", "NATIONAL_ID"] },
                    "identifier": { "type": "string" },
                    "expiration_date": { "type": "string", "description": "YYYY-MM-DD" }
                  }
                },
                "phone": {
                  "type": "object",
                  "properties": {
                    "country_code": { "type": "string" },
                    "number": { "type": "string" }
                  }
                },
                "date_of_birth": { "type": "string", "description": "YYYY-MM-DD" },
                "email": { "type": "string" },
                "address": {
                  "type": "object",
                  "properties": {
                    "line1": { "type": "string" },
                    "line2": { "type": "string" },
                    "city": { "type": "string" },
                    "state": { "type": "string" },
                    "postal_code": { "type": "string" },
                    "country": { "type": "string", "description": "ISO 3166-1 alpha-2 country code." }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": { "type": "array", "items": { "type": "object", "properties": { "field_name": { "type": "string" }, "message": { "type": "string" } } } }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "This list endpoint uses cursor-based pagination via data.cursor.next / data.cursor.previous — pass the cursor string back as the next= or previous= query parameter. Do not synthesize cursor values client-side.",
    "size must be between 10 and 50 inclusive (default 10). Values outside this range return a 400 REQUEST_NOT_VALID error.",
    "Senders are returned under data.senders (an array), not data (which is an object containing both cursor and senders).",
    "Sender IDs returned here are opaque strings. Pass them as-is to get/delete_transfer_sender — do not apply encodeURIComponent."
  ]
}
