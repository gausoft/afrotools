{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "list_customers",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": [
    "GHS",
    "KES",
    "NGN",
    "RWF",
    "SLE",
    "TZS",
    "UGX",
    "XAF",
    "XOF",
    "ZAR",
    "ZMW"
  ],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/customers"
  },
  "example_prompt": "List Flutterwave customers with pagination, retrieving 20 customers per page.",
  "input_schema": {
    "type": "object",
    "properties": {
      "page": {
        "type": "integer",
        "minimum": 1,
        "default": 1,
        "description": "Page number to retrieve (1-based). The most recent data entry is on page 1."
      },
      "size": {
        "type": "integer",
        "minimum": 10,
        "maximum": 50,
        "default": 10,
        "description": "Number of customers per page. Defaults to 10. Must be between 10 and 50."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": {
        "type": "string",
        "enum": ["success"],
        "description": "Response status."
      },
      "message": {
        "type": "string"
      },
      "meta": {
        "type": "object",
        "properties": {
          "page_info": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "current_page": { "type": "integer" },
              "total_pages": { "type": "integer" }
            }
          }
        }
      },
      "data": {
        "type": "array",
        "description": "Maximum 10 items per response.",
        "items": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "description": "Unique customer identifier (e.g. cus_3XarBILKQS)."
            },
            "email": {
              "type": "string",
              "format": "email"
            },
            "name": {
              "type": "object",
              "properties": {
                "first": { "type": "string" },
                "middle": { "type": ["string", "null"] },
                "last": { "type": "string" }
              }
            },
            "phone": {
              "type": "object",
              "properties": {
                "country_code": { "type": "string" },
                "number": { "type": "string" }
              }
            },
            "address": {
              "type": ["object", "null"],
              "properties": {
                "line1": { "type": "string" },
                "line2": { "type": ["string", "null"] },
                "city": { "type": "string" },
                "state": { "type": "string" },
                "country": { "type": "string" },
                "postal_code": { "type": "string" }
              }
            },
            "meta": {
              "type": ["object", "null"],
              "additionalProperties": true
            },
            "created_datetime": {
              "type": "string",
              "format": "date-time"
            }
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            },
            "description": "Present on 400 validation errors."
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "Query parameters (page, size) are passed as URL query string parameters, not in the request body. The size parameter must be between 10 and 50; values outside this range return a 400 validation error.",
    "Pagination metadata is at meta.page_info (with fields total, current_page, total_pages) — there is no size or per_page field in the page_info object. Maximum 10 items are returned in data per response.",
    "Always send an X-Trace-Id header (12-255 chars, e.g. a UUID v4) on every request to make Flutterwave support debugging tractable.",
    "Validation error items use the key 'field_name' (not 'field') — match on error.validation_errors[].field_name when surfacing per-field errors to users."
  ]
}
