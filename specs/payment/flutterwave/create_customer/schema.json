{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "create_customer",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": [
    "GHS",
    "KES",
    "NGN",
    "RWF",
    "SLE",
    "TZS",
    "UGX",
    "XAF",
    "XOF",
    "ZAR",
    "ZMW"
  ],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "POST",
    "url": "https://f4bexperience.flutterwave.com/customers"
  },
  "example_prompt": "Create a Flutterwave customer with an email address, full name and phone number so they can be billed later.",
  "input_schema": {
    "type": "object",
    "required": ["email", "name", "phone"],
    "properties": {
      "email": {
        "type": "string",
        "format": "email",
        "description": "Customer email address (required)."
      },
      "name": {
        "type": "object",
        "description": "Structured customer name (required).",
        "required": ["first", "last"],
        "properties": {
          "first": {
            "type": "string",
            "minLength": 2,
            "maxLength": 50,
            "pattern": "^(?![ ,.'-]*$)[A-Za-z ,.'-]{2,50}$",
            "description": "First name (2-50 chars). Pattern ^(?![ ,.'-]*$)[A-Za-z ,.'-]{2,50}$ — letters, spaces, commas, periods, apostrophes, hyphens; cannot be only punctuation."
          },
          "middle": {
            "type": "string",
            "minLength": 2,
            "maxLength": 50,
            "pattern": "^(?![ ,.'-]*$)[A-Za-z ,.'-]{2,50}$",
            "description": "Middle name (2-50 chars, optional). Same pattern as first."
          },
          "last": {
            "type": "string",
            "minLength": 2,
            "maxLength": 50,
            "pattern": "^(?![ ,.'-]*$)[A-Za-z ,.'-]{2,50}$",
            "description": "Last name (2-50 chars). Same pattern as first."
          }
        }
      },
      "phone": {
        "type": "object",
        "description": "Structured customer phone (required).",
        "required": ["country_code", "number"],
        "properties": {
          "country_code": {
            "type": "string",
            "pattern": "^[0-9]{1,3}$",
            "description": "Dialing prefix without '+' (1-3 digits, e.g. '234' for Nigeria)."
          },
          "number": {
            "type": "string",
            "pattern": "^[0-9]{7,10}$",
            "description": "Local subscriber number (7-10 digits, digits only)."
          }
        }
      },
      "address": {
        "type": "object",
        "description": "Optional postal address. When provided, line1, city, state, postal_code and country are required (non-empty).",
        "required": ["line1", "city", "state", "postal_code", "country"],
        "properties": {
          "line1": { "type": "string", "minLength": 1, "description": "Street address line 1 (non-empty)." },
          "line2": { "type": "string", "description": "Street address line 2 (optional)." },
          "city": { "type": "string", "minLength": 1 },
          "state": { "type": "string", "minLength": 1 },
          "postal_code": { "type": "string", "minLength": 1 },
          "country": {
            "type": "string",
            "pattern": "^[A-Z]{2}$",
            "description": "ISO 3166-1 alpha-2 country code, uppercase (e.g. 'US', 'NG')."
          }
        }
      },
      "meta": {
        "type": "object",
        "description": "Free-form metadata stored against the customer (string key -> string value).",
        "additionalProperties": { "type": "string" }
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": {
        "type": "string",
        "enum": ["success"]
      },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique customer identifier (e.g. cus_3XarBILKQS)."
          },
          "email": { "type": "string", "format": "email" },
          "name": {
            "type": "object",
            "properties": {
              "first": { "type": "string" },
              "middle": { "type": ["string", "null"] },
              "last": { "type": "string" }
            }
          },
          "phone": {
            "type": "object",
            "properties": {
              "country_code": { "type": "string" },
              "number": { "type": "string" }
            }
          },
          "address": {
            "type": ["object", "null"],
            "properties": {
              "line1": { "type": "string" },
              "line2": { "type": ["string", "null"] },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "postal_code": { "type": "string" },
              "country": { "type": "string" }
            }
          },
          "meta": {
            "type": ["object", "null"],
            "additionalProperties": true
          },
          "created_datetime": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            },
            "description": "Present on 400 validation errors."
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "name and phone are nested objects, not flat strings. Sending name as a string (e.g. 'name': 'Jane Doe') triggers a 400 validation error — use { first, last } at minimum.",
    "name.first / name.middle / name.last must each be 2-50 chars and contain only letters, spaces, hyphens, apostrophes, commas, and periods. Single-character names ('A') and digits in names fail validation.",
    "phone.country_code must be 1-3 digits without the leading '+' (e.g. '234' for Nigeria). phone.number must be 7-10 digits, local subscriber portion only — leading zeros and the country code go in country_code.",
    "Always send an X-Idempotency-Key header (12-255 chars) on POST /customers so safe retries do not create duplicate customer records. Also send X-Trace-Id for support traceability.",
    "Creating a customer with an email that already exists for the merchant returns HTTP 409 (error.type 'RESOURCE_CONFLICT', code '10409') — handle this case by fetching the existing customer instead of treating it as a hard error.",
    "Validation error items use the key 'field_name' (not 'field') — match on error.validation_errors[].field_name when surfacing per-field errors to users."
  ]
}
