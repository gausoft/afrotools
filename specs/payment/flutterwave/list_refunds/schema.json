{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "list_refunds",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/refunds"
  },
  "example_prompt": "List Flutterwave refunds created in January 2024, 20 per page.",
  "input_schema": {
    "type": "object",
    "properties": {
      "page": {
        "type": "integer",
        "minimum": 1,
        "default": 1,
        "description": "The page of the data to retrieve. The most recent data is on page 1."
      },
      "size": {
        "type": "integer",
        "minimum": 10,
        "maximum": 50,
        "default": 10,
        "description": "Length of data returned. Min 10, max 50. Defaults to 10."
      },
      "from": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 start date-time of the period to retrieve refunds for."
      },
      "to": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 end date-time of the period to retrieve refunds for."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value (12-255 chars) for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": { "type": "string", "enum": ["success"] },
      "message": { "type": "string" },
      "meta": {
        "type": "object",
        "properties": {
          "page_info": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "current_page": { "type": "integer" },
              "total_pages": { "type": "integer" }
            }
          }
        }
      },
      "data": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "amount_refunded": { "type": "number" },
            "meta": { "type": "object", "additionalProperties": true },
            "reason": {
              "type": "string",
              "enum": ["duplicate", "fraudulent", "requested_by_customer", "expired_uncaptured_charge"]
            },
            "status": {
              "type": "string",
              "enum": ["pending", "requires_action", "succeeded", "failed", "cancelled", "completed", "new"]
            },
            "charge_id": { "type": "string" },
            "created_datetime": { "type": "string", "format": "date-time" }
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": { "type": "array", "items": { "type": "object", "properties": { "field_name": { "type": "string" }, "message": { "type": "string" } } } }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "Page size is bounded by the API: 10 minimum, 50 maximum. Defaults to 10.",
    "from and to must be ISO 8601 date-times. The most recent refunds are on page 1.",
    "Refund objects expose amount_refunded (not amount) and created_datetime (not created_at). reason and status are constrained enums — use the exact strings shown in the schema."
  ]
}
