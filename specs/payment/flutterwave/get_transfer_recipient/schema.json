{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "get_transfer_recipient",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/transfers/recipients/{id}"
  },
  "example_prompt": "Fetch the full details of a Flutterwave transfer recipient by id to verify the destination account before issuing a payout.",
  "input_schema": {
    "type": "object",
    "required": ["id"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique Flutterwave identifier of the transfer recipient."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": { "type": "string", "enum": ["success", "failed"] },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string", "description": "One of: bank, mobile_money, wallet, cash_pickup, crypto." },
          "name": {
            "type": ["object", "null"],
            "properties": {
              "first": { "type": "string" },
              "middle": { "type": "string" },
              "last": { "type": "string" }
            }
          },
          "currency": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "phone": {
            "type": ["object", "null"],
            "properties": {
              "country_code": { "type": "string" },
              "number": { "type": "string" }
            }
          },
          "address": {
            "type": ["object", "null"],
            "properties": {
              "line1": { "type": "string" },
              "line2": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "country": { "type": "string" },
              "postal_code": { "type": "string" }
            }
          },
          "bank": { "type": ["object", "null"], "description": "Present when type is bank." },
          "mobile_money": { "type": ["object", "null"], "description": "Present when type is mobile_money." },
          "wallet": { "type": ["object", "null"], "description": "Present when type is wallet." },
          "cash_pickup": { "type": ["object", "null"], "description": "Present when type is cash_pickup." },
          "crypto": { "type": ["object", "null"], "description": "Present when type is crypto." }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "id is the Flutterwave-assigned recipient id (returned by create_transfer_recipient), not a merchant reference. To look up by reference, page through list_transfer_recipients and match client-side.",
    "Type-specific destination details live on sibling keys (bank, mobile_money, wallet, cash_pickup, crypto) on the response data — read the `type` field first to know which sibling is populated.",
    "Recipient IDs are opaque strings. Pass them as-is into the path — do not apply encodeURIComponent.",
    "A 404 response means the recipient does not exist or has been deleted. The endpoint does not distinguish between these cases."
  ]
}
