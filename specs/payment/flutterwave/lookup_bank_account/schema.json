{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "lookup_bank_account",
  "capability_type": "synchronous",
  "status": "ready",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "POST",
    "url": "https://f4bexperience.flutterwave.com/banks/account-resolve"
  },
  "example_prompt": "Resolve the account holder name for NGN account 0690000040 at bank code 058 before initiating a Nigerian bank transfer.",
  "input_schema": {
    "type": "object",
    "description": "Body shape is discriminated by the currency field. NGN expects a simple {code, number}; GBP expects {code, number, type, name|business_name}; USD expects {code, number, country}.",
    "oneOf": [
      {
        "title": "NGN",
        "type": "object",
        "required": ["currency", "account"],
        "properties": {
          "currency": { "type": "string", "enum": ["NGN"] },
          "account": {
            "type": "object",
            "required": ["code", "number"],
            "properties": {
              "code": {
                "type": "string",
                "pattern": "^[0-9]{3,10}$",
                "description": "Local CBN bank code (3-10 digits)."
              },
              "number": {
                "type": "string",
                "pattern": "^[0-9]{10}$",
                "description": "10-digit Nigerian NUBAN account number."
              }
            }
          }
        }
      },
      {
        "title": "GBP",
        "type": "object",
        "required": ["currency", "account"],
        "properties": {
          "currency": { "type": "string", "enum": ["GBP"] },
          "account": {
            "type": "object",
            "required": ["code", "number", "type"],
            "properties": {
              "code": { "type": "string", "minLength": 2, "maxLength": 10, "description": "UK sort code or routing code." },
              "number": { "type": "string", "description": "GBP account number." },
              "type": { "type": "string", "enum": ["personal", "corporate"] },
              "name": {
                "type": "object",
                "description": "Required when type=personal.",
                "properties": {
                  "first": { "type": "string", "minLength": 2, "maxLength": 50 },
                  "last": { "type": "string", "minLength": 2, "maxLength": 50 },
                  "middle": { "type": "string", "minLength": 2, "maxLength": 50 }
                },
                "required": ["first", "last"]
              },
              "business_name": {
                "type": "string",
                "minLength": 2,
                "maxLength": 50,
                "description": "Required when type=corporate."
              }
            }
          }
        }
      },
      {
        "title": "USD",
        "type": "object",
        "required": ["currency", "account"],
        "properties": {
          "currency": { "type": "string", "enum": ["USD"] },
          "account": {
            "type": "object",
            "required": ["code", "number", "country"],
            "properties": {
              "code": { "type": "string", "minLength": 2, "maxLength": 10, "description": "US routing code." },
              "number": { "type": "string", "description": "USD account number." },
              "country": { "type": "string", "enum": ["NG"], "description": "Only NG is currently supported as the account holder country for USD lookups." }
            }
          }
        }
      }
    ]
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": { "type": "string", "enum": ["success", "failed"] },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "required": ["bank_code", "account_number", "account_name"],
        "properties": {
          "bank_code": { "type": "string", "description": "Bank code that was resolved." },
          "account_number": { "type": "string", "description": "Account number that was resolved." },
          "account_name": { "type": "string", "description": "Legal name registered on the account." }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "The request body is discriminated by currency. NGN expects {currency:'NGN', account:{code, number}}. GBP and USD have different nested shapes (GBP needs type+name|business_name; USD needs account.country='NG'). Sending an NGN-shaped body for a GBP lookup returns 400 REQUEST_NOT_VALID.",
    "Always confirm the returned account_name with the user before triggering a payout. Account-name spoofing is the most common social-engineering attack on payout flows.",
    "Headers X-Trace-Id (12-255 chars) and X-Scenario-Key (1-1000 chars, sandbox only) are optional. Use X-Scenario-Key in sandbox to simulate auth_redirect / failed_lookup behaviours."
  ]
}
