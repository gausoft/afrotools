{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "get_order",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/orders/{id}"
  },
  "example_prompt": "Fetch the full details of a Flutterwave v4 order by its id to verify its current status.",
  "input_schema": {
    "type": "object",
    "required": ["id"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique Flutterwave identifier of the order to retrieve (e.g. ord_EFAHCzELJb)."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "properties": {
      "status": { "type": "string", "enum": ["success", "failed"] },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Flutterwave order id, e.g. ord_WRq7L4TM8p." },
          "amount": { "type": "number", "minimum": 0.01 },
          "fees": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "description": "Fee type, e.g. 'vat'." },
                "amount": { "type": "number" }
              }
            }
          },
          "billing_details": {
            "type": "object",
            "properties": {
              "email": { "type": "string" },
              "name": {
                "type": "object",
                "properties": {
                  "first": { "type": "string" },
                  "middle": { "type": "string" },
                  "last": { "type": "string" }
                }
              },
              "phone": {
                "type": "object",
                "properties": {
                  "country_code": { "type": "string" },
                  "number": { "type": "string" }
                }
              }
            }
          },
          "currency": { "type": "string" },
          "customer_id": { "type": "string" },
          "description": { "type": "string" },
          "meta": { "type": "object", "additionalProperties": true },
          "next_action": {
            "type": "object",
            "additionalProperties": true,
            "description": "Discriminated next-step instruction (redirect_url, requires_otp, requires_pin, payment_instruction, requires_bank_transfer, qr_code, requires_capture, requires_requery, requires_additional_fields)."
          },
          "payment_method_details": {
            "type": "object",
            "additionalProperties": true,
            "description": "Object discriminated by payment method type (card, mobile_money, bank_account, opay, applepay, googlepay, ussd, bank_transfer)."
          },
          "redirect_url": { "type": "string", "format": "uri" },
          "reference": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["completed", "pending", "authorized", "partially-completed", "voided", "failed"]
          },
          "processor_response": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "description": "e.g. 'approved'." },
              "code": { "type": "string", "description": "e.g. '00'." }
            },
            "additionalProperties": true
          },
          "created_datetime": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            },
            "description": "Present on 400 validation errors."
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "Order date field is created_datetime (ISO 8601 with optional sub-second precision), not created_at.",
    "id is the Flutterwave-assigned order id (prefix ord_), not the merchant reference. To look up by reference, use list_orders and match client-side.",
    "payment_method_details and processor_response shapes depend on the underlying payment method type; treat unknown sub-fields permissively.",
    "Always verify status server-side via this endpoint before fulfilling — never trust client-side redirects alone."
  ]
}
