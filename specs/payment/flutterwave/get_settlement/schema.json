{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "get_settlement",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/settlements/{id}"
  },
  "example_prompt": "Fetch the Flutterwave settlement with id stl_abc123 to inspect its status and constituent charges.",
  "input_schema": {
    "type": "object",
    "required": ["id"],
    "properties": {
      "id": {
        "type": "string",
        "description": "The settlement id (path parameter)."
      },
      "page": {
        "type": "integer",
        "minimum": 1,
        "default": 1,
        "description": "Page number for the embedded charges list (1-indexed)."
      },
      "size": {
        "type": "integer",
        "minimum": 10,
        "maximum": 50,
        "default": 10,
        "description": "Page size for the embedded charges list (10 to 50)."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "properties": {
      "status": { "type": "string", "description": "\"success\" or \"failed\"." },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "net_amount": { "type": "number" },
          "gross_amount": { "type": "number" },
          "currency": { "type": "string" },
          "status": {
            "type": "string",
            "enum": [
              "disburse-pending",
              "pending",
              "reviewed",
              "approved",
              "completed",
              "completed-offline",
              "failed",
              "flagged",
              "processing",
              "on-hold"
            ]
          },
          "due_datetime": { "type": "string", "format": "date-time" },
          "transaction_datetime": { "type": "string", "format": "date-time" },
          "settlement_account": { "type": "string" },
          "fees": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string" },
                "amount": { "type": "number" }
              }
            }
          },
          "chargeback": { "type": "number" },
          "refund": { "type": "number" },
          "charge_count": { "type": "string" },
          "charges": {
            "type": "array",
            "description": "Charges included in this settlement.",
            "items": {
              "type": "object",
              "properties": {
                "id": { "type": "string" },
                "charged_amount": { "type": "number" },
                "settlement_amount": { "type": "number" }
              },
              "additionalProperties": true
            }
          },
          "created_datetime": { "type": "string", "format": "date-time" }
        }
      },
      "meta": {
        "type": "object",
        "properties": {
          "page_info": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "current_page": { "type": "integer" },
              "total_pages": { "type": "integer" }
            }
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "The id path parameter must be the Flutterwave-issued settlement id, not your merchant reference.",
    "The response embeds the underlying charges array; page and size query params paginate that list (10 to 50 per page) and the page_info appears under meta.",
    "Settlement amounts are split into net_amount (paid out) and gross_amount (before fees); use the fees[] breakdown plus chargeback and refund totals to reconcile."
  ]
}
