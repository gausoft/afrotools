{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "create_order",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "POST",
    "url": "https://f4bexperience.flutterwave.com/orders"
  },
  "example_prompt": "Create a Flutterwave v4 order for 500 NGN charged to an existing customer with a saved card payment method.",
  "input_schema": {
    "type": "object",
    "required": ["amount", "currency", "reference", "customer_id", "payment_method_id"],
    "properties": {
      "amount": {
        "type": "number",
        "minimum": 0.01,
        "description": "Order amount in the major unit of the currency."
      },
      "currency": {
        "type": "string",
        "description": "ISO 4217 currency code, e.g. NGN, GHS, KES."
      },
      "reference": {
        "type": "string",
        "minLength": 6,
        "maxLength": 42,
        "pattern": "^[A-Za-z0-9-]{6,42}$",
        "description": "Merchant-provided unique reference (alphanumeric and hyphens, 6-42 chars)."
      },
      "customer_id": {
        "type": "string",
        "description": "Identifier of the Flutterwave customer that owns this order."
      },
      "payment_method_id": {
        "type": "string",
        "description": "Identifier of the payment method to charge for this order."
      },
      "meta": {
        "type": "object",
        "description": "Arbitrary merchant metadata stored alongside the order. Per docs, values are strings.",
        "additionalProperties": { "type": "string" }
      },
      "redirect_url": {
        "type": "string",
        "format": "uri",
        "description": "URL the customer is redirected to after payment completion."
      },
      "authorization": {
        "type": "object",
        "description": "Optional 3DS / strong-customer-authentication payload (oneOf 3ds_authorization_in shapes) when required by the payment method.",
        "additionalProperties": true
      },
      "merchant_vat_amount": {
        "type": "number",
        "description": "Optional VAT amount included in the order, in the major unit of the currency."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      },
      "idempotency_key": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Idempotency-Key header to safely retry the same order creation."
      },
      "scenario_key": {
        "type": "string",
        "minLength": 1,
        "maxLength": 1000,
        "description": "Optional X-Scenario-Key header used in sandbox to simulate specific scenarios."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "properties": {
      "status": { "type": "string", "enum": ["success", "failed"] },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Flutterwave order id, e.g. ord_WRq7L4TM8p." },
          "amount": { "type": "number", "minimum": 0.01 },
          "fees": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "description": "Fee type, e.g. 'vat'." },
                "amount": { "type": "number" }
              }
            }
          },
          "billing_details": {
            "type": "object",
            "properties": {
              "email": { "type": "string" },
              "name": {
                "type": "object",
                "properties": {
                  "first": { "type": "string" },
                  "middle": { "type": "string" },
                  "last": { "type": "string" }
                }
              },
              "phone": {
                "type": "object",
                "properties": {
                  "country_code": { "type": "string" },
                  "number": { "type": "string" }
                }
              }
            }
          },
          "currency": { "type": "string" },
          "customer_id": { "type": "string" },
          "description": { "type": "string" },
          "meta": { "type": "object", "additionalProperties": true },
          "next_action": {
            "type": "object",
            "description": "Discriminated next-step instruction by `type` (redirect_url, requires_additional_fields, requires_pin, requires_requery, requires_otp, payment_instruction, requires_capture, requires_bank_transfer, qr_code).",
            "properties": {
              "type": {
                "type": "string",
                "enum": [
                  "redirect_url",
                  "requires_additional_fields",
                  "requires_pin",
                  "requires_requery",
                  "requires_otp",
                  "payment_instruction",
                  "requires_capture",
                  "requires_bank_transfer",
                  "qr_code"
                ]
              },
              "redirect_url": {
                "type": "object",
                "properties": {
                  "url": { "type": "string", "format": "uri" }
                }
              },
              "requires_additional_fields": {
                "type": "object",
                "properties": {
                  "fields": { "type": "array", "items": { "type": "string" } }
                }
              },
              "requires_pin": { "type": "object", "additionalProperties": true },
              "requires_requery": { "type": "object", "additionalProperties": true },
              "requires_otp": { "type": "object", "additionalProperties": true },
              "payment_instruction": {
                "type": "object",
                "properties": {
                  "note": { "type": "string" }
                }
              },
              "requires_capture": { "type": "object", "additionalProperties": true },
              "requires_bank_transfer": {
                "type": "object",
                "properties": {
                  "account_number": { "type": "string" },
                  "account_type": { "type": "string" },
                  "account_bank_name": { "type": "string" },
                  "account_expiration_datetime": { "type": "string", "format": "date-time" },
                  "note": { "type": "string" }
                }
              },
              "qr_code": {
                "type": "object",
                "properties": {
                  "image": { "type": "string", "description": "Data URI, e.g. data:image/png;base64,..." }
                }
              }
            },
            "additionalProperties": true
          },
          "payment_method_details": {
            "type": "object",
            "description": "Embedded payment method snapshot. Includes id/type/customer_id/meta/device_fingerprint/client_ip/created_datetime plus a per-type sub-object (card, mobile_money, etc.).",
            "properties": {
              "id": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["card", "bank_account", "mobile_money", "opay", "applepay", "googlepay", "ussd", "bank_transfer"]
              },
              "customer_id": { "type": "string" },
              "meta": { "type": "object", "additionalProperties": true },
              "device_fingerprint": { "type": "string" },
              "client_ip": { "type": "string" },
              "created_datetime": { "type": "string", "format": "date-time" },
              "card": {
                "type": "object",
                "properties": {
                  "expiry_month": { "type": "integer" },
                  "expiry_year": { "type": "integer" },
                  "first6": { "type": "string" },
                  "last4": { "type": "string" },
                  "network": {
                    "type": "string",
                    "enum": ["MASTERCARD", "VISA", "AMERICAN EXPRESS", "DISCOVER", "VERVE", "AFRIGO", "UNKNOWN"]
                  },
                  "card_holder_name": { "type": "string" },
                  "billing_address": { "type": "object", "additionalProperties": true },
                  "cof": {
                    "type": "object",
                    "properties": {
                      "enabled": { "type": "boolean" },
                      "agreement_id": { "type": "string" },
                      "recurring_amount_variability": { "type": "string" },
                      "agreement_type": { "type": "string" },
                      "trace_id": { "type": "string" }
                    }
                  }
                }
              }
            },
            "additionalProperties": true
          },
          "redirect_url": { "type": "string", "format": "uri" },
          "reference": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["completed", "pending", "authorized", "partially-completed", "voided", "failed"]
          },
          "processor_response": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "description": "e.g. 'approved', 'refer_to_issuer', 'insufficient_funds', 'expired_card', 'incorrect_pin', 'suspected_fraud', 'system_error'." },
              "code": { "type": "string", "description": "Numeric processor code, e.g. '00', '01', '51', '54', '55', '59', '96'." }
            },
            "additionalProperties": true
          },
          "created_datetime": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            },
            "description": "Present on 400 validation errors."
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "reference must be unique per merchant and 6-42 characters (alphanumeric and hyphens); reusing a reference returns 409 RESOURCE_CONFLICT.",
    "amount uses the major unit of the currency (e.g. 500 NGN, not 50000 kobo) — different from many v3 endpoints that took minor units.",
    "Send X-Idempotency-Key (12-255 chars) when retrying order creation to guarantee at-most-once semantics; the same key returns the original response.",
    "customer_id and payment_method_id must already exist; create them first via /customers and /payment-methods.",
    "Successful response is 201 Created with status='success'. The response data may include next_action (3DS redirect, wallet auth) and processor_response — inspect them before fulfilling.",
    "Errors: 10400 REQUEST_NOT_VALID (validation), 10401 UNAUTHORIZED (token), 10403 FORBIDDEN (scope), 10409 RESOURCE_CONFLICT (duplicate reference)."
  ]
}
