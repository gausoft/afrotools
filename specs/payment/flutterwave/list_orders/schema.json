{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "list_orders",
  "capability_type": "synchronous",
  "status": "ready",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/orders"
  },
  "example_prompt": "List Flutterwave v4 orders created in the last 7 days with status completed, paginated 20 per page.",
  "input_schema": {
    "type": "object",
    "required": [],
    "properties": {
      "status": {
        "type": "string",
        "enum": ["completed", "pending", "authorized", "partially-completed", "voided", "failed"],
        "description": "Filter orders by lifecycle status."
      },
      "from": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 date-time lower bound for order creation date."
      },
      "to": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 date-time upper bound for order creation date."
      },
      "customer_id": {
        "type": "string",
        "description": "Filter orders by customer identifier."
      },
      "payment_method_id": {
        "type": "string",
        "description": "Filter orders by payment method identifier."
      },
      "page": {
        "type": "integer",
        "minimum": 1,
        "default": 1,
        "description": "Page number (1-indexed). Most recent data is on page 1."
      },
      "size": {
        "type": "integer",
        "minimum": 10,
        "maximum": 50,
        "default": 10,
        "description": "Page size, between 10 and 50."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "properties": {
      "status": { "type": "string", "enum": ["success", "failed"] },
      "message": { "type": "string" },
      "meta": {
        "type": "object",
        "properties": {
          "page_info": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "current_page": { "type": "integer" },
              "total_pages": { "type": "integer" }
            }
          }
        }
      },
      "data": {
        "type": "array",
        "description": "Array of order objects. Maximum 10 items per page per Flutterwave docs.",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "description": "Flutterwave order id, e.g. ord_WRq7L4TM8p." },
            "amount": { "type": "number", "minimum": 0.01 },
            "fees": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "type": { "type": "string", "description": "Fee type, e.g. 'vat'." },
                  "amount": { "type": "number" }
                }
              }
            },
            "billing_details": {
              "type": "object",
              "properties": {
                "email": { "type": "string" },
                "name": {
                  "type": "object",
                  "properties": {
                    "first": { "type": "string" },
                    "middle": { "type": "string" },
                    "last": { "type": "string" }
                  }
                },
                "phone": {
                  "type": "object",
                  "properties": {
                    "country_code": { "type": "string" },
                    "number": { "type": "string" }
                  }
                }
              }
            },
            "currency": { "type": "string", "description": "ISO 4217 code (e.g. NGN, GHS, KES, USD)." },
            "customer_id": { "type": "string" },
            "description": { "type": "string" },
            "meta": { "type": "object", "additionalProperties": true },
            "next_action": {
              "type": "object",
              "additionalProperties": true,
              "description": "Discriminated next-step instruction (redirect_url, requires_otp, requires_pin, payment_instruction, requires_bank_transfer, qr_code, requires_capture, requires_requery, requires_additional_fields)."
            },
            "payment_method_details": {
              "type": "object",
              "additionalProperties": true,
              "description": "Object discriminated by payment method type (card, mobile_money, bank_account, opay, applepay, googlepay, ussd, bank_transfer)."
            },
            "redirect_url": { "type": "string", "format": "uri" },
            "reference": { "type": "string" },
            "status": {
              "type": "string",
              "enum": ["completed", "pending", "authorized", "partially-completed", "voided", "failed"]
            },
            "processor_response": {
              "type": "object",
              "properties": {
                "type": { "type": "string", "description": "e.g. 'approved', 'refer_to_issuer', 'insufficient_funds', 'expired_card', 'incorrect_pin', 'suspected_fraud', 'system_error'." },
                "code": { "type": "string", "description": "Numeric processor code, e.g. '00', '01', '51', '54', '55', '59', '96'." }
              },
              "additionalProperties": true
            },
            "created_datetime": { "type": "string", "format": "date-time" }
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            },
            "description": "Present on 400 validation errors."
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "Pagination metadata is nested under meta.page_info with current_page, total_pages, total — not flat meta.page/meta.size/meta.total.",
    "Order date field is created_datetime (ISO 8601 with optional sub-second precision), not created_at.",
    "Each order item includes a payment_method_details object whose shape varies by the underlying payment method type (card, mobile_money, bank_account, etc.).",
    "All query parameters are optional. The size parameter is bounded to [10, 50] — values outside this range will be rejected by the API.",
    "Use ISO 8601 date-time strings for from/to (e.g. 2024-01-01T00:00:00Z). Plain date-only values may be rejected.",
    "Provide X-Trace-Id (12-255 chars) on every request for distributed-trace correlation in Flutterwave's logs."
  ]
}
