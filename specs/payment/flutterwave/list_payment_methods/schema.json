{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "list_payment_methods",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/payment-methods"
  },
  "example_prompt": "List the saved Flutterwave v4 payment methods, 20 per page, to power a checkout selector.",
  "input_schema": {
    "type": "object",
    "required": [],
    "properties": {
      "page": {
        "type": "integer",
        "minimum": 1,
        "default": 1,
        "description": "Page number (1-indexed). Most recent data is on page 1."
      },
      "size": {
        "type": "integer",
        "minimum": 10,
        "maximum": 50,
        "default": 10,
        "description": "Page size, between 10 and 50."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "properties": {
      "status": { "type": "string", "enum": ["success", "failed"] },
      "message": { "type": "string" },
      "meta": {
        "type": "object",
        "properties": {
          "page_info": {
            "type": "object",
            "properties": {
              "total": { "type": "integer" },
              "current_page": { "type": "integer" },
              "total_pages": { "type": "integer" }
            }
          }
        }
      },
      "data": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "type": {
              "type": "string",
              "enum": ["card", "bank_account", "mobile_money", "opay", "applepay", "googlepay", "ussd", "bank_transfer"]
            },
            "customer_id": { "type": "string" },
            "created_datetime": { "type": "string", "format": "date-time" }
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "field_name": { "type": "string" },
                "message": { "type": "string" }
              }
            },
            "description": "Present on 400 validation errors."
          }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "Pagination metadata is nested under meta.page_info with current_page, total_pages, total — not flat meta.page/meta.size/meta.total.",
    "Each list item is summary-only (id, type, customer_id, created_datetime). Type-specific details (card last4, mobile_money number, etc.) are returned by get_payment_method, not by list.",
    "type may include 'bank_transfer' in addition to the create_payment_method enum (card | bank_account | mobile_money | opay | applepay | googlepay | ussd).",
    "size is bounded to [10, 50]; values outside the range are rejected. Maximum 10 items are returned per request even at higher page sizes per current docs — check current_page/total_pages to paginate."
  ]
}
