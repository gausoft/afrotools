{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "get_transfer_sender",
  "capability_type": "synchronous",
  "status": "ready",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "GET",
    "url": "https://f4bexperience.flutterwave.com/transfers/senders/{id}"
  },
  "example_prompt": "Fetch the full details of a Flutterwave transfer sender by id to verify the funding source before issuing a payout.",
  "input_schema": {
    "type": "object",
    "required": ["id"],
    "properties": {
      "id": {
        "type": "string",
        "description": "ID of the transfer sender (returned by create_transfer_sender)."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": { "type": "string", "enum": ["success", "failed"], "description": "\"success\" on 200." },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "required": ["id"],
        "properties": {
          "id": { "type": "string" },
          "name": {
            "type": "object",
            "properties": {
              "first": { "type": "string" },
              "middle": { "type": "string" },
              "last": { "type": "string" }
            }
          },
          "national_identification": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["PASSPORT", "DRIVERS_LICENSE", "NATIONAL_ID"] },
              "identifier": { "type": "string" },
              "expiration_date": { "type": "string", "description": "YYYY-MM-DD" }
            }
          },
          "phone": {
            "type": "object",
            "properties": {
              "country_code": { "type": "string" },
              "number": { "type": "string" }
            }
          },
          "date_of_birth": { "type": "string", "description": "YYYY-MM-DD" },
          "email": { "type": "string" },
          "address": {
            "type": "object",
            "properties": {
              "line1": { "type": "string" },
              "line2": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "country": { "type": "string" },
              "postal_code": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": { "type": "array", "items": { "type": "object", "properties": { "field_name": { "type": "string" }, "message": { "type": "string" } } } }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "id is the Flutterwave-assigned sender id (returned by create_transfer_sender), not a merchant reference. To look up by something else, page through list_transfer_senders and match client-side.",
    "Sender IDs are opaque strings. Pass them as-is into the path — do not apply encodeURIComponent.",
    "A 404 NOT_FOUND response means the sender does not exist or has been deleted. The endpoint does not distinguish between these cases.",
    "The response shape depends on the sender variant that was created (bank_egp / mobile_money_egp / bank_gbp / bank_eur / generic_sender). Fields like national_identification or date_of_birth are absent on variants that did not require them."
  ]
}
