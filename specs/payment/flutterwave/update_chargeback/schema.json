{
  "spec_version": "1.0",
  "provider_api_version": "v4",
  "capability": "update_chargeback",
  "capability_type": "synchronous",
  "status": "draft",
  "currency": ["GHS", "KES", "NGN", "RWF", "SLE", "TZS", "UGX", "XAF", "XOF", "ZAR", "ZMW"],
  "auth": {
    "type": "oauth2",
    "location": "header",
    "field": "Authorization",
    "format": "Bearer {access_token}",
    "env_var": "FLUTTERWAVE_CLIENT_CREDENTIALS"
  },
  "endpoint": {
    "method": "PUT",
    "url": "https://f4bexperience.flutterwave.com/chargebacks/{id}"
  },
  "example_prompt": "Attach additional evidence to a pending Flutterwave chargeback and accept it.",
  "input_schema": {
    "type": "object",
    "required": ["id"],
    "properties": {
      "id": {
        "type": "string",
        "description": "The chargeback id (path parameter)."
      },
      "status": {
        "type": "string",
        "enum": ["accepted", "declined"],
        "description": "New status. Only accepted or declined are accepted on update."
      },
      "uploaded_proof": {
        "type": "string",
        "description": "URL to an uploaded proof document."
      },
      "comment": {
        "type": "string",
        "description": "Additional comment about the update."
      },
      "provider": {
        "type": "string",
        "description": "Provider name (e.g. Visa)."
      },
      "arn": {
        "type": "string",
        "description": "Acquirer Reference Number."
      },
      "due_datetime": {
        "type": "string",
        "format": "date-time",
        "description": "ISO 8601 date-time to override the chargeback due date."
      },
      "proof_data": {
        "type": "string",
        "description": "Base64-encoded proof document body (alternative to uploaded_proof URL)."
      },
      "trace_id": {
        "type": "string",
        "minLength": 12,
        "maxLength": 255,
        "description": "Optional X-Trace-Id header value (12-255 chars) for request correlation."
      }
    }
  },
  "response_schema": {
    "type": "object",
    "required": ["status", "data"],
    "properties": {
      "status": { "type": "string", "enum": ["success"] },
      "message": { "type": "string" },
      "data": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "charge_id": { "type": "string" },
          "amount": { "type": "number" },
          "meta": { "type": "object", "additionalProperties": true },
          "stage": {
            "type": "string",
            "enum": ["new", "second", "pre-arbitration", "arbitration", "invalid"]
          },
          "status": {
            "type": "string",
            "enum": ["pending", "accepted", "declined", "initiated", "won", "lost", "reversed", "new"]
          },
          "type": { "type": "string", "enum": ["local", "international"] },
          "due_datetime": { "type": "string", "format": "date-time" },
          "created_datetime": { "type": "string", "format": "date-time" },
          "updated_datetime": { "type": "string", "format": "date-time" },
          "settlement_id": { "type": "string" },
          "uploaded_proof": { "type": "string" },
          "comment": { "type": "string" },
          "provider": { "type": "string" },
          "arn": { "type": "string" },
          "initiator": { "type": "string" }
        }
      }
    }
  },
  "error_schema": {
    "type": "object",
    "required": ["status", "error"],
    "properties": {
      "status": { "type": "string", "enum": ["failed"] },
      "message": { "type": "string" },
      "error": {
        "type": "object",
        "required": ["type", "code", "message"],
        "properties": {
          "type": { "type": "string", "description": "REQUEST_NOT_VALID | UNAUTHORIZED | FORBIDDEN | RESOURCE_CONFLICT | NOT_FOUND" },
          "code": { "type": "string", "description": "Numeric code as string: 10400, 10401, 10403, 10404, 10409" },
          "message": { "type": "string" },
          "validation_errors": { "type": "array", "items": { "type": "object", "properties": { "field_name": { "type": "string" }, "message": { "type": "string" } } } }
        }
      }
    }
  },
  "gotchas": [
    "Flutterwave v4 uses OAuth2 client credentials. POST client_id and client_secret as form-encoded body to https://idp.flutterwave.com/realms/flutterwave/protocol/openid-connect/token to obtain an access_token (valid 10 minutes), then use it as Bearer in the Authorization header. The FLUTTERWAVE_CLIENT_CREDENTIALS env var stores base64(client_id:client_secret).",
    "On update, status only accepts the enum values accepted or declined. Other final states (won/lost/reversed) are set by the system, not by the merchant.",
    "Two ways to attach proof: uploaded_proof (URL to an already-hosted document) or proof_data (base64-encoded document body). Pick one — do not send both.",
    "Status transitions are typically one-way once accepted or declined; inspect the response.data.status to confirm the new state before notifying the customer."
  ]
}
